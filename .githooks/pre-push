#!/usr/bin/env sh
set -e

# ============================================================================
# PRE-PUSH HOOK: Mirror CI checks before pushing
# ============================================================================
# This hook runs the same checks as CI to catch issues before they reach
# the remote. Auto-fixes formatting issues where possible, then verifies.
#
# Checks performed:
#   1. Prettier formatting (Markdown, JSON, asmdef/asmref, YAML, JS)
#   2. Markdownlint
#   3. Spell checking (cspell)
#   4. Doc link lint
#   5. Gitignore docs safety (no docs/ files accidentally gitignored)
#   6. Unity meta file lint (missing/orphaned .meta files)
#   7. EOL normalization and verification
#   8. yamllint (if installed)
#   9. actionlint (if installed and workflow files changed)
#  10. External link check with lychee (if installed)
#  11. Test lifecycle lint
#  12. License year audit
#  13. Hook pattern tests (if hook files changed)
#  14. LLM instructions validation
#
# LINE ENDING NOTE:
#   This repo uses CRLF for most files (.gitattributes).
#   EXCEPTIONS that MUST use LF:
#     - YAML files (.yml, .yaml) - cross-platform compatibility
#     - Shell scripts (.sh) - Unix requirement
#     - .github/** ALL files - GitHub Actions run on Linux, Dependabot commits LF
#       This includes .github/*.md files (copilot-instructions.md, etc.)
#   If you encounter EOL-related CI failures, run: npm run fix:eol
# ============================================================================

# Ensure Node is available
if ! command -v npx >/dev/null 2>&1; then
  echo "npx not found; skipping Node-based checks. CI will validate." >&2
else
  # Check if npm dependencies are installed
  if [ ! -d "node_modules" ]; then
    echo "node_modules not found. Run 'npm install' to enable local pre-push checks, or skip - CI will validate." >&2
  else
    # 1) Prettier checks (Markdown, JSON, asmdef/asmref, YAML, JS)
    # File patterns match CI workflows:
    #   - markdown-json.yml: **/*.{md,markdown} and **/*.{json,jsonc,asmdef,asmref}
    #   - yaml-format-lint.yml: **/*.{yml,yaml}
    # Auto-fix first, then verify. If verification fails, the user needs to commit the fixes.
    if npx --no-install prettier --version >/dev/null 2>&1; then
      echo "Checking formatting with patterns matching CI..."
      echo "  Patterns: **/*.{md,markdown,json,jsonc,asmdef,asmref,yml,yaml,js}"
      if ! npx --no-install prettier --check -- "**/*.{md,markdown,json,jsonc,asmdef,asmref,yml,yaml,js}" 2>/dev/null; then
        echo ""
        echo "=== Prettier formatting issues detected ==="
        echo "Auto-fixing formatting..."
        npx --no-install prettier --write --log-level warn -- "**/*.{md,markdown,json,jsonc,asmdef,asmref,yml,yaml,js}"
        echo ""
        echo "Files have been auto-formatted. Please:"
        echo "  1. Review the changes: git diff"
        echo "  2. Stage and commit: git add -A && git commit --amend --no-edit"
        echo "  3. Push again: git push"
        echo ""
        exit 1
      fi
      echo "✓ Prettier formatting OK"
    else
      echo "prettier not installed; skipping format check. Run 'npm install' or CI will validate." >&2
    fi

    # 2) Markdownlint (uses repo config and ignore list)
    if npx --no-install markdownlint --version >/dev/null 2>&1; then
      npx --no-install markdownlint --config .markdownlint.json --ignore-path .markdownlintignore -- "**/*.md" "**/*.markdown" || exit 1
    else
      echo "markdownlint not installed; skipping markdown lint. Run 'npm install' or CI will validate." >&2
    fi

    # 3) Spell checking (cspell - validates all files for spelling errors)
    if npx --no-install cspell --version >/dev/null 2>&1; then
      echo "Checking spelling..."
      if ! npm run lint:spelling 2>/dev/null; then
        echo ""
        echo "=== Spelling errors detected ==="
        echo "To fix spelling issues:"
        echo "  1. Fix the typos in the reported files"
        echo "  2. Or add valid technical terms to the appropriate dictionary in cspell.json:"
        echo "     - unity-terms: Unity Engine APIs and components"
        echo "     - csharp-terms: C# language and .NET types"
        echo "     - package-terms: This package's API names"
        echo "     - tech-terms: General programming/tooling terms"
        echo "     See: .llm/skills/linter-reference.md for details"
        echo "  3. Stage and commit your changes"
        echo "  4. Push again: git push"
        echo ""
        exit 1
      fi
      echo "✓ Spell check OK"

      # 3b) cspell.json config lint (case-redundant entries, etc.)
      echo "Checking cspell.json configuration..."
      if ! node scripts/lint-cspell-config.js 2>/dev/null; then
        echo ""
        echo "=== cspell.json configuration issues ==="
        echo "Run: npm run lint:spelling:config:fix"
        echo "Then re-format: npx prettier --write cspell.json"
        echo ""
        exit 1
      fi
      echo "✓ cspell.json config OK"
    else
      echo "cspell not installed; skipping spell check. Run 'npm install' or CI will validate." >&2
    fi

    # 4) Doc link lint (validates internal links, relative prefixes, and broken references)
    # This runs the same PowerShell linter as the CI to catch issues before push
    echo "Checking documentation links..."
    node ./scripts/run-doc-link-lint.js || exit 1
    echo "✓ Doc links OK"
  fi
fi

# 5) Gitignore docs safety (validates no docs/ files are accidentally gitignored)
# This catches the category of bug where a .gitignore wildcard pattern like
# "failed-tests-*" accidentally matches "docs/features/editor-tools/failed-tests-exporter.md"
if command -v pwsh >/dev/null 2>&1; then
  echo "Checking gitignore docs safety..."
  pwsh -NoProfile -File scripts/lint-gitignore-docs.ps1 || {
    echo ""
    echo "=== Gitignore docs safety check failed ==="
    echo "Fix .gitignore patterns to avoid excluding documentation files."
    echo "Example: Narrow 'failed-tests-*' to 'failed-tests-*.txt'"
    echo ""
    exit 1
  }
  echo "✓ Gitignore docs safety OK"
elif command -v powershell >/dev/null 2>&1; then
  echo "Checking gitignore docs safety..."
  powershell -NoProfile -ExecutionPolicy Bypass -File scripts/lint-gitignore-docs.ps1 || {
    echo ""
    echo "=== Gitignore docs safety check failed ==="
    echo "Fix .gitignore patterns to avoid excluding documentation files."
    echo "Example: Narrow 'failed-tests-*' to 'failed-tests-*.txt'"
    echo ""
    exit 1
  }
  echo "✓ Gitignore docs safety OK"
else
  echo "PowerShell not found; skipping gitignore docs safety check. CI will validate." >&2
fi

# 6) Unity meta file lint (validates all files have .meta and no orphaned .meta exist)
# This catches missing .meta files before they reach CI
if command -v pwsh >/dev/null 2>&1; then
  echo "Checking Unity meta files..."
  pwsh -NoProfile -File scripts/lint-meta-files.ps1 || {
    echo ""
    echo "=== Unity meta file lint failed ==="
    echo "Run './scripts/generate-meta.sh <path>' to generate missing meta files."
    echo "Delete orphaned .meta files or restore missing source files."
    echo ""
    exit 1
  }
  echo "✓ Unity meta files OK"
elif command -v powershell >/dev/null 2>&1; then
  echo "Checking Unity meta files..."
  powershell -NoProfile -ExecutionPolicy Bypass -File scripts/lint-meta-files.ps1 || {
    echo ""
    echo "=== Unity meta file lint failed ==="
    echo "Run './scripts/generate-meta.sh <path>' to generate missing meta files."
    echo "Delete orphaned .meta files or restore missing source files."
    echo ""
    exit 1
  }
  echo "✓ Unity meta files OK"
else
  echo "PowerShell not found; skipping Unity meta file lint. CI will validate." >&2
fi

# EOL policy (CRLF for most, LF for YAML/shell) - auto-fix then verify
if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File scripts/normalize-eol.ps1
  pwsh -NoProfile -File scripts/check-eol.ps1 -VerboseOutput
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File scripts/normalize-eol.ps1
  powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-eol.ps1 -VerboseOutput
else
  echo "PowerShell not found; skipping EOL validation." >&2
fi

# Optional YAML lint (if yamllint installed)
if command -v yamllint >/dev/null 2>&1; then
  echo "Running yamllint..."
  yamllint -c .yamllint.yaml -- .
  echo "✓ yamllint OK"
else
  echo "yamllint not found; skipping YAML lint. CI will catch issues." >&2
fi

# Optional external link check (if lychee installed)
if command -v lychee >/dev/null 2>&1; then
  # Exclude node_modules to avoid scanning hundreds of third-party markdown files
  lychee -c .lychee.toml --no-progress --verbose --exclude-path node_modules --exclude-path .git -- "**/*.md"
else
  echo "lychee not found; skipping external link check. CI will run lychee." >&2
fi

# Test lifecycle lint (UNH001-UNH003: lifecycle, UNH004: naming conventions, UNH005: null checks)
if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File scripts/lint-tests.ps1 -VerboseOutput || {
    echo ""
    echo "=== Test lint failed ==="
    echo "Fix the issues above or add // UNH-SUPPRESS comments for valid exceptions."
    echo "For naming convention errors (UNH004):"
    echo "  - Use PascalCase or dot notation in TestName/SetName (e.g., 'Input.Null.ReturnsFalse')"
    echo "  - Use PascalCase for TestCaseSource method names (e.g., 'EdgeCaseTestData')"
    echo "For null check errors (UNH005):"
    echo "  - Use Assert.IsTrue(x != null) instead of Assert.IsNotNull(x)"
    echo "  - Use Assert.IsTrue(x == null) instead of Assert.IsNull(x)"
    echo "  - Why: Unity's == operator performs special 'fake null' checking"
    echo "Auto-fix null asserts: pwsh -NoProfile -File scripts/lint-tests.ps1 -FixNullChecks -Paths <test files>"
    echo ""
    exit 1
  }
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File scripts/lint-tests.ps1 -VerboseOutput || {
    echo ""
    echo "=== Test lint failed ==="
    echo "Fix the issues above or add // UNH-SUPPRESS comments for valid exceptions."
    echo "For naming convention errors (UNH004):"
    echo "  - Use PascalCase or dot notation in TestName/SetName (e.g., 'Input.Null.ReturnsFalse')"
    echo "  - Use PascalCase for TestCaseSource method names (e.g., 'EdgeCaseTestData')"
    echo "For null check errors (UNH005):"
    echo "  - Use Assert.IsTrue(x != null) instead of Assert.IsNotNull(x)"
    echo "  - Use Assert.IsTrue(x == null) instead of Assert.IsNull(x)"
    echo "  - Why: Unity's == operator performs special 'fake null' checking"
    echo "Auto-fix null asserts: powershell -NoProfile -ExecutionPolicy Bypass -File scripts/lint-tests.ps1 -FixNullChecks -Paths <test files>"
    echo ""
    exit 1
  }
else
  echo 'PowerShell not found; skipping test lints.' >&2
fi

# 12) License year audit (validates copyright year headers in .cs files)
# Note: This scans all .cs files using git log and can take 40-60 seconds on large repos
echo "Checking license year headers..."
if ! bash scripts/audit-license-years.sh --summary; then
  echo ""
  echo "=== License year audit failed ==="
  echo "Some .cs files have incorrect copyright year headers."
  echo "To auto-fix: bash scripts/update-license-headers.sh"
  echo "To see details: bash scripts/audit-license-years.sh --csv"
  echo ""
  exit 1
fi
echo "✓ License year headers OK"

# Check for forbidden #region/#endregion directives in ALL C# files
# This is a full repository scan (not just staged files) to catch any regions before push
# Regions are forbidden in this codebase - see .llm/skills/no-regions.md
echo "Checking for forbidden #region directives in C# files..."
REGION_VIOLATIONS=$(grep -r -n -i '^\s*#\s*region\|^\s*#\s*endregion' --include="*.cs" Runtime/ Editor/ Tests/ Samples~/ 2>/dev/null || true)
if [ -n "$REGION_VIOLATIONS" ]; then
  echo ""
  echo "=== Error: C# regions (#region/#endregion) are forbidden ==="
  echo "The following files contain regions:"
  echo "$REGION_VIOLATIONS" | head -50
  VIOLATION_COUNT=$(echo "$REGION_VIOLATIONS" | wc -l)
  if [ "$VIOLATION_COUNT" -gt 50 ]; then
    echo "... and $((VIOLATION_COUNT - 50)) more violations"
  fi
  echo ""
  echo "Remove all #region and #endregion directives before pushing."
  echo "See .llm/skills/no-regions.md for guidance on code organization alternatives."
  echo ""
  exit 1
fi
echo "✓ No #region directives found"

# Wiki generation tests (validates sidebar format, link transformations)
# This mirrors the validate-wiki-links.yml CI workflow
WIKI_CHANGES=$(git diff --name-only @{upstream}..HEAD 2>/dev/null | grep -E '^(scripts/wiki/|scripts/tests/test-wiki-generation\.sh|\.github/workflows/deploy-wiki\.yml)' || true)
if [ -z "$WIKI_CHANGES" ]; then
  # Also check staged/uncommitted wiki-related changes
  WIKI_CHANGES=$(git diff --name-only HEAD 2>/dev/null | grep -E '^(scripts/wiki/|scripts/tests/test-wiki-generation\.sh|\.github/workflows/deploy-wiki\.yml)' || true)
fi

if [ -n "$WIKI_CHANGES" ]; then
  echo "Wiki-related files changed:"
  echo "$WIKI_CHANGES" | sed 's/^/  /'
  echo "Running wiki generation tests..."
  if ! bash scripts/tests/test-wiki-generation.sh; then
    echo ""
    echo "=== Wiki generation tests failed ==="
    echo "Fix the issues in scripts/wiki/*.py or scripts/tests/test-wiki-generation.sh"
    echo ""
    exit 1
  fi
  echo "✓ Wiki generation tests OK"
  
  # Also run Python wiki tests if pytest is available
  if command -v python3 >/dev/null 2>&1 && python3 -c "import pytest" 2>/dev/null; then
    echo "Running Python wiki script tests..."
    if ! python3 -m pytest scripts/wiki/test_wiki_scripts.py -v; then
      echo ""
      echo "=== Python wiki tests failed ==="
      echo "Fix the issues in scripts/wiki/*.py"
      echo ""
      exit 1
    fi
    echo "✓ Python wiki tests OK"
  else
    echo "pytest not installed; skipping Python wiki tests. CI will run them." >&2
  fi
fi

# Test lint script tests (validates lint-tests.ps1 allowlist and rule detection)
# Runs when lint-tests.ps1 or its test script change
LINT_TEST_CHANGES=$(git diff --name-only @{upstream}..HEAD 2>/dev/null | grep -E '^(scripts/lint-tests\.ps1|scripts/tests/test-lint-tests\.ps1)' || true)
if [ -z "$LINT_TEST_CHANGES" ]; then
  LINT_TEST_CHANGES=$(git diff --name-only HEAD 2>/dev/null | grep -E '^(scripts/lint-tests\.ps1|scripts/tests/test-lint-tests\.ps1)' || true)
fi

if [ -n "$LINT_TEST_CHANGES" ]; then
  echo "Lint test files changed:"
  echo "$LINT_TEST_CHANGES" | sed 's/^/  /'
  echo "Running lint-tests.ps1 test suite..."
  if command -v pwsh >/dev/null 2>&1; then
    if ! pwsh -NoProfile -File scripts/tests/test-lint-tests.ps1; then
      echo ""
      echo "=== Lint test suite failed ==="
      echo "Fix the issues in scripts/lint-tests.ps1 or scripts/tests/test-lint-tests.ps1"
      echo ""
      exit 1
    fi
    echo "✓ Lint test suite OK"
  elif command -v powershell >/dev/null 2>&1; then
    if ! powershell -NoProfile -File scripts/tests/test-lint-tests.ps1; then
      echo ""
      echo "=== Lint test suite failed ==="
      echo "Fix the issues in scripts/lint-tests.ps1 or scripts/tests/test-lint-tests.ps1"
      echo ""
      exit 1
    fi
    echo "✓ Lint test suite OK"
  else
    echo "PowerShell not found; skipping lint test suite. CI will catch issues." >&2
  fi
fi

# Hook pattern tests (validates bash case pattern matching behavior)
# Runs when hook files or the test script itself change
HOOK_PATTERN_CHANGES=$(git diff --name-only @{upstream}..HEAD 2>/dev/null | grep -E '^(\.githooks/|scripts/tests/test-hook-patterns\.sh)' || true)
if [ -z "$HOOK_PATTERN_CHANGES" ]; then
  # Also check staged/uncommitted hook-related changes
  HOOK_PATTERN_CHANGES=$(git diff --name-only HEAD 2>/dev/null | grep -E '^(\.githooks/|scripts/tests/test-hook-patterns\.sh)' || true)
fi

if [ -n "$HOOK_PATTERN_CHANGES" ]; then
  echo "Hook-related files changed:"
  echo "$HOOK_PATTERN_CHANGES" | sed 's/^/  /'
  echo "Running hook pattern tests..."
  if ! bash scripts/tests/test-hook-patterns.sh; then
    echo ""
    echo "=== Hook pattern tests failed ==="
    echo "Fix the issues in .githooks/ or scripts/tests/test-hook-patterns.sh"
    echo ""
    exit 1
  fi
  echo "✓ Hook pattern tests OK"
fi

# actionlint check for GitHub Actions workflows (only if workflow files changed)
# This mirrors the actionlint.yml CI workflow
# Use @{upstream} to compare against the remote tracking branch
WORKFLOW_CHANGES=$(git diff --name-only @{upstream}..HEAD 2>/dev/null | grep -E '^\.github/workflows/' || true)
if [ -z "$WORKFLOW_CHANGES" ]; then
  # Also check staged/uncommitted workflow changes
  WORKFLOW_CHANGES=$(git diff --name-only HEAD 2>/dev/null | grep -E '^\.github/workflows/' || true)
fi

if [ -n "$WORKFLOW_CHANGES" ]; then
  echo "GitHub Actions workflow files changed:"
  echo "$WORKFLOW_CHANGES" | sed 's/^/  /'
  if command -v actionlint >/dev/null 2>&1; then
    echo "Running actionlint..."
    if ! actionlint; then
      echo ""
      echo "=== actionlint found issues ==="
      echo "Fix the workflow issues before pushing."
      echo ""
      exit 1
    fi
    echo "✓ actionlint OK"
  else
    echo "actionlint not installed; skipping workflow lint." >&2
    echo "Install: go install github.com/rhysd/actionlint/cmd/actionlint@latest" >&2
    echo "CI will run actionlint and catch any issues." >&2
  fi
fi

# LLM instructions validation (skills index, trigger comments, etc.)
if command -v pwsh >/dev/null 2>&1; then
  echo "Validating LLM instructions..."
  pwsh -NoProfile -File scripts/lint-llm-instructions.ps1 || {
    echo ""
    echo "=== LLM instructions validation failed ==="
    echo "Run: pwsh -NoProfile -File scripts/lint-llm-instructions.ps1 -Fix"
    echo ""
    exit 1
  }
  echo "✓ LLM instructions OK"
elif command -v powershell >/dev/null 2>&1; then
  echo "Validating LLM instructions..."
  powershell -NoProfile -ExecutionPolicy Bypass -File scripts/lint-llm-instructions.ps1 || {
    echo ""
    echo "=== LLM instructions validation failed ==="
    echo "Run: powershell -NoProfile -File scripts/lint-llm-instructions.ps1 -Fix"
    echo ""
    exit 1
  }
  echo "✓ LLM instructions OK"
else
  echo "PowerShell not found; skipping LLM instructions validation." >&2
fi

# ============================================================================
# FINAL VERIFICATION SUMMARY
# ============================================================================
echo ""
echo "Pre-push checks complete. Push proceeding..."
